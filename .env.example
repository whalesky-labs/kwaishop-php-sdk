# Test-only environment variables.
# This file is only a template for local test setup.
# Runtime SDK usage does not read this file.
# Copy it to `.env` when PHPUnit or manual test helpers need fixed credentials.

# -------------------------------------------------------------------
# Application credentials
# -------------------------------------------------------------------
# Official app key from the Kuaishou open platform.
KWAISHOP_TEST_APP_KEY=your-test-app-key

# OAuth app secret used for token exchange.
KWAISHOP_TEST_APP_SECRET=your-test-app-secret

# Request signing secret.
KWAISHOP_TEST_SIGN_SECRET=your-test-sign-secret

# -------------------------------------------------------------------
# OAuth test tokens
# -------------------------------------------------------------------
# Optional access token for local integration-style tests.
KWAISHOP_TEST_ACCESS_TOKEN=your-test-access-token

# Optional refresh token for token refresh tests.
KWAISHOP_TEST_REFRESH_TOKEN=your-test-refresh-token

# Optional open_id returned by OAuth flows.
KWAISHOP_TEST_OPEN_ID=your-test-open-id

# OAuth redirect URI used for manual authorization flow checks.
KWAISHOP_TEST_REDIRECT_URI=https://your-callback.test/oauth/callback

# -------------------------------------------------------------------
# Message push / decryption
# -------------------------------------------------------------------
# Optional AES private key used by the platform message service.
# Official docs describe this as the app-specific message decryption key.
KWAISHOP_TEST_MESSAGE_PRIVATE_KEY=your-test-message-private-key

# -------------------------------------------------------------------
# Endpoint override
# -------------------------------------------------------------------
# Override only when tests need a non-default API base URL.
KWAISHOP_TEST_BASE_URL=https://openapi.kwaixiaodian.com
