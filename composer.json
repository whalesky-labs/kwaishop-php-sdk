{
    "name": "westng/kwaishop-php-sdk",
    "description": "PHP SDK for Kuaishou E-commerce Open Platform.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "kuaishou",
        "kwaishop",
        "ecommerce",
        "openapi",
        "sdk",
        "php"
    ],
    "homepage": "https://github.com/westng/kwaishop-php-sdk",
    "authors": [
        {
            "name": "westng"
        }
    ],
    "support": {
        "issues": "https://github.com/westng/kwaishop-php-sdk/issues",
        "source": "https://github.com/westng/kwaishop-php-sdk"
    },
    "require": {
        "php": "^8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "KwaiShopSDK\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KwaiShopSDK\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "cs-fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "cs-check": "php-cs-fixer fix --config=.php-cs-fixer.php --dry-run --diff",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
